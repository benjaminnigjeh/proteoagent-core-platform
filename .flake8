[flake8]
max-line-length = 120
# E221: multiple spaces before operator (intentional alignment in dicts/assignments)
extend-ignore = E221
exclude = .venv,__pycache__
# flask_app.py has an inline HTML/JS template with unavoidably long lines
per-file-ignores =
    flask_app.py:E501
    agents/supervisor_agent.py:E501
    agents/tests/test_*.py:E302,E501
    agents/multi_agent.py:E501,W503
    agents/*_backend.py:E501,E401,E302,E701,E702,E231,E127,E251,E741,W503,F401,F841
    agents/*_specialist.py:E501,E701,E702,W503
    agents/raw_worker.py:E501,E401,E251,F841,W503
